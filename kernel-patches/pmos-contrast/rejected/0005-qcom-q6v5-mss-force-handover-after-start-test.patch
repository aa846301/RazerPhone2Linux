diff --git a/drivers/remoteproc/qcom_q6v5_mss.c b/drivers/remoteproc/qcom_q6v5_mss.c
index 000000000000..000000000000 100644
--- a/drivers/remoteproc/qcom_q6v5_mss.c
+++ b/drivers/remoteproc/qcom_q6v5_mss.c
@@ -1618,6 +1618,8 @@ static void qcom_q6v5_dump_segment(struct rproc *rproc,
 	}
 }
 
+static void qcom_msa_handover(struct qcom_q6v5 *q6v5);
+
 static int q6v5_start(struct rproc *rproc)
 {
 	struct q6v5 *qproc = rproc->priv;
@@ -1641,6 +1643,14 @@ static int q6v5_start(struct rproc *rproc)
 		goto reclaim_mpss;
 	}
 
