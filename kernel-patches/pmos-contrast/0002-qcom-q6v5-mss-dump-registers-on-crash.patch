+static void q6v5_mss_diag_dump_reg(struct q6v5 *qproc, const char *reason,
+				   const char *name, void __iomem *base,
+				   u32 offset)
+{
+	dev_err(qproc->dev, "mss diag %s: %s[0x%03x]=0x%08x\n",
+		reason, name, offset, readl(base + offset));
+}
+
+static void q6v5_mss_crash_dump(struct qcom_q6v5 *q6v5, const char *reason)
+{
+	struct q6v5 *qproc = container_of(q6v5, struct q6v5, q6v5);
+
+	dev_err(qproc->dev, "mss diag %s: begin register dump\n", reason);
+
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_MBA_IMAGE", qproc->rmb_base,
+			       RMB_MBA_IMAGE_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_PBL_STATUS", qproc->rmb_base,
+			       RMB_PBL_STATUS_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_MBA_COMMAND", qproc->rmb_base,
+			       RMB_MBA_COMMAND_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_MBA_STATUS", qproc->rmb_base,
+			       RMB_MBA_STATUS_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_PMI_META", qproc->rmb_base,
+			       RMB_PMI_META_DATA_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_PMI_CODE_START", qproc->rmb_base,
+			       RMB_PMI_CODE_START_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_PMI_CODE_LENGTH", qproc->rmb_base,
+			       RMB_PMI_CODE_LENGTH_REG);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_MBA_MSS_STATUS", qproc->rmb_base,
+			       RMB_MBA_MSS_STATUS);
+	q6v5_mss_diag_dump_reg(qproc, reason, "RMB_MBA_ALT_RESET", qproc->rmb_base,
+			       RMB_MBA_ALT_RESET);
+
+	/*
+	 * Do not read qproc->reg_base or halt_map here. On the Razer Phone 2
+	 * pmOS contrast kernel, post-fatal QDSP6/halt reads trigger a
+	 * synchronous external abort from the IRQ thread. The RMB window above
+	 * has been verified safe and is enough to capture MBA/MSS status.
+	 */
+	dev_err(qproc->dev, "mss diag %s: end register dump\n", reason);
+}
+
