					status = "disabled";
				};

				apr-service@b {
					compatible = "qcom,q6cvp";
					reg = <0x0b>;
					qcom,protection-domain = "avs/audio\0msm/adsp/audio_pd";
					status = "disabled";
				};
			};

			fastrpc {
				compatible = "qcom,fastrpc";
				qcom,glink-channels = "fastrpcglink-apps-dsp";
