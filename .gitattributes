*.img filter=lfs diff=lfs merge=lfs -text
*.sh text eol=lf
*.py text eol=lf
*.dts text eol=lf
*.dtsi text eol=lf
*.config text eol=lf
*.env text eol=lf
*.md text eol=lf
*.ps1 text eol=crlf
# Anything consumed by the WSL build or shipped into the rootfs/initramfs
# must stay LF on disk; CRLF here breaks git-apply and on-device shells.
*.patch text eol=lf
*.c text eol=lf
*.h text eol=lf
*.service text eol=lf
*.conf text eol=lf
rootfs-scripts/initramfs-tools/** text eol=lf
# Firmware blobs are opaque binaries: never eol-convert or diff as text.
firmware/** -text -diff
