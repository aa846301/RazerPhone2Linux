+/* ---- QMI-over-QRTR debug dump (parse_qmi_kernel_dump compatible) ----
+ * Opt-in via qrtr.qmi_dump=1 on the kernel cmdline, or at runtime through
+ * /sys/module/qrtr/parameters/qmi_dump. Each QMI DATA SDU crossing QRTR is
+ * printed as an @QMI@<qmi .../> XML record so the sdm845-mainline
+ * parse_qmi_kernel_dump tool can decode it from:
+ *   dmesg -t | grep "@QMI@" | sed -e "s/@QMI@//g" > qmi_dump.xml
+ * svc_id is resolved from QRTR_TYPE_NEW_SERVER announcements (service<->port).
+ */
+static bool qmi_dump;
+module_param(qmi_dump, bool, 0644);
+MODULE_PARM_DESC(qmi_dump, "Dump QMI messages over QRTR as @QMI@ XML");
+
+#define QRTR_QMI_MAP_MAX 96
+struct qrtr_qmi_svc_ent {
+	u32 node;
+	u32 port;
+	u32 service;
+	bool used;
+};
+static struct qrtr_qmi_svc_ent qrtr_qmi_map[QRTR_QMI_MAP_MAX];
+static DEFINE_SPINLOCK(qrtr_qmi_map_lock);
+
+static void qrtr_qmi_record_server(u32 service, u32 node, u32 port)
+{
+	unsigned long flags;
+	int i, free = -1;
+
+	spin_lock_irqsave(&qrtr_qmi_map_lock, flags);
+	for (i = 0; i < QRTR_QMI_MAP_MAX; i++) {
+		if (qrtr_qmi_map[i].used &&
+		    qrtr_qmi_map[i].node == node &&
+		    qrtr_qmi_map[i].port == port) {
+			qrtr_qmi_map[i].service = service;
+			spin_unlock_irqrestore(&qrtr_qmi_map_lock, flags);
+			return;
+		}
+		if (free < 0 && !qrtr_qmi_map[i].used)
+			free = i;
+	}
+	if (free >= 0) {
+		qrtr_qmi_map[free].node = node;
+		qrtr_qmi_map[free].port = port;
+		qrtr_qmi_map[free].service = service;
+		qrtr_qmi_map[free].used = true;
+	}
+	spin_unlock_irqrestore(&qrtr_qmi_map_lock, flags);
+}
+
+static int qrtr_qmi_lookup_svc(u32 node, u32 port)
+{
+	unsigned long flags;
+	int i, svc = -1;
+
+	spin_lock_irqsave(&qrtr_qmi_map_lock, flags);
+	for (i = 0; i < QRTR_QMI_MAP_MAX; i++) {
+		if (qrtr_qmi_map[i].used &&
+		    qrtr_qmi_map[i].node == node &&
+		    qrtr_qmi_map[i].port == port) {
+			svc = qrtr_qmi_map[i].service;
+			break;
+		}
+	}
+	spin_unlock_irqrestore(&qrtr_qmi_map_lock, flags);
+	return svc;
+}
+
+static void qrtr_qmi_dump(const char *dir, u32 rnode, u32 rport,
+			  const u8 *buf, size_t len)
+{
+	unsigned int type, txn, msg;
+	int svc;
+	size_t i;
+
+	if (!qmi_dump || !buf || !len)
+		return;
+
+	svc = qrtr_qmi_lookup_svc(rnode, rport);
+
+	/* QMI SDU: [flags][txn][msg_id][len][tlv]; ctrl svc(0) uses 1-byte txn */
+	type = buf[0];
+	if (svc == 0) {
+		txn = (len > 1) ? buf[1] : 0;
+		msg = (len > 3) ? (buf[2] | (buf[3] << 8)) : 0;
+	} else {
+		txn = (len > 2) ? (buf[1] | (buf[2] << 8)) : 0;
+		msg = (len > 4) ? (buf[3] | (buf[4] << 8)) : 0;
+	}
+
+	printk(KERN_INFO
+	       "@QMI@<qmi svc_id=\"0x%02x\" type=\"%u\" txn_id=\"%x\" msg_id=\"0x%04x\" android_process=\"%s:%u:%u\">\n",
+	       (svc < 0) ? 0xff : (svc & 0xff), type, txn, msg, dir, rnode, rport);
+	for (i = 0; i < len; i += 16)
+		printk(KERN_INFO "@QMI@%*ph\n",
+		       (int)min_t(size_t, 16, len - i), buf + i);
+	printk(KERN_INFO "@QMI@</qmi>\n");
+}
