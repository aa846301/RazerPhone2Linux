From 1f0bc3e66e0900d1ec7f0aec6ead4e6bc2f6fd39 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Thu, 18 Jun 2026 18:00:00 +0800
Subject: [PATCH] ath10k: snoc: add force_skip_host_cap diagnostic parameter

Razer Phone 2 now reaches WLFW service 69 after serving the downstream
wlanmdsp.mbn TFTP path, but WLFW rejects the immediately following MSA_INFO
request with QMI_ERR_INCOMPATIBLE_STATE_V01.

Known-working SDM845 devices differ on the host capability exchange:
OnePlus 6 uses the 8-bit host-cap quirk while Xiaomi beryllium skips the
host-cap request entirely.  Add a diagnostic module parameter so the skip
variant can be tested with a same-release live ath10k_snoc module, without
changing or flashing the DTB.

This is disabled by default and is not a production policy.
---
 drivers/net/wireless/ath/ath10k/qmi.c | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath10k/qmi.c b/drivers/net/wireless/ath/ath10k/qmi.c
index 3055edc8e065..ae4a697c3a2a 100644
--- a/drivers/net/wireless/ath/ath10k/qmi.c
+++ b/drivers/net/wireless/ath/ath10k/qmi.c
@@ -26,6 +26,11 @@
 #define SMEM_IMAGE_VERSION_ENTRY_SIZE	128
 #define SMEM_IMAGE_VERSION_NAME_SIZE	75
 
+static bool force_skip_host_cap;
+module_param(force_skip_host_cap, bool, 0644);
+MODULE_PARM_DESC(force_skip_host_cap,
+		 "Skip the WLFW host capability request for live diagnostics");
+
 static int ath10k_qmi_map_msa_permission(struct ath10k_qmi *qmi,
 					 struct ath10k_msa_mem_info *mem_info)
 {
@@ -824,7 +829,11 @@ static void ath10k_qmi_event_server_arrive(struct ath10k_qmi *qmi)
 	 * Skip the host capability request for the firmware versions which
 	 * do not support this feature.
 	 */
-	if (!test_bit(ATH10K_SNOC_FLAG_SKIP_HOST_CAP_QUIRK, &ar_snoc->flags)) {
+	if (force_skip_host_cap)
+		ath10k_warn(ar, "forcing WLFW host capability request skip\n");
+
+	if (!force_skip_host_cap &&
+	    !test_bit(ATH10K_SNOC_FLAG_SKIP_HOST_CAP_QUIRK, &ar_snoc->flags)) {
 		ret = ath10k_qmi_host_cap_send_sync(qmi);
 		if (ret)
 			return;
