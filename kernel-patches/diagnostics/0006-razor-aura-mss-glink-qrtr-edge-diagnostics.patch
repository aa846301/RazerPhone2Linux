+static bool qcom_glink_diag_is_mss_edge(const struct qcom_glink *glink)
+{
+	const char *devname;
+	const char *label;
+
+	if (!glink || !glink->dev)
+		return false;
+
+	devname = dev_name(glink->dev);
+	label = glink->label ?: "";
+
+	return strstr(devname, "4080000.remoteproc") ||
+	       strstr(devname, "modem") ||
+	       strstr(devname, "mpss") ||
+	       strstr(label, "modem") ||
+	       strstr(label, "mpss");
+}
