@@ -243,19 +243,65 @@ struct q6v5 {
 	const char *hexagon_mdt_image;
 	int version;
 };
 
 enum {
 	MSS_MSM8909,
 	MSS_MSM8916,
 	MSS_MSM8953,
 	MSS_MSM8974,
 	MSS_MSM8996,
 	MSS_MSM8998,
 	MSS_SC7180,
