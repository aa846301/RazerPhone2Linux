diff --git a/drivers/remoteproc/qcom_q6v5_mss.c b/drivers/remoteproc/qcom_q6v5_mss.c
index 6f77fd24eeca..cf5e8c08f413 100644
--- a/drivers/remoteproc/qcom_q6v5_mss.c
+++ b/drivers/remoteproc/qcom_q6v5_mss.c
@@ -699,6 +699,14 @@ static int q6v5proc_reset(struct q6v5 *qproc)
 	int i;
 
 	if (qproc->version == MSS_SDM845) {
+		/*
+		 * Razer downstream marks the MSS node with qcom,override-acc.
+		 * Mainline only applies this write on older non-SDM845 paths.
+		 * Test whether aura's modem firmware expects the ACC strap before
+		 * Q6 boot.
+		 */
+		dev_info(qproc->dev, "sdm845 mss diag: applying ACC override\n");
+		writel(QDSP6SS_ACC_OVERRIDE_VAL, qproc->reg_base + QDSP6SS_STRAP_ACC);
+
 		val = readl(qproc->reg_base + QDSP6SS_SLEEP);
 		val |= Q6SS_CBCR_CLKEN;
 		writel(val, qproc->reg_base + QDSP6SS_SLEEP);
