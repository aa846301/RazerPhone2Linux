	sound {
		compatible = "qcom,sdm845-sndcard";
		model = "Razer Phone 2";
		pinctrl-0 = <0xfe 0xff 0x100>;
		pinctrl-names = "default";
		status = "disabled";
		audio-routing = "RX_BIAS\0MCLK\0AMIC1\0MIC BIAS3\0AMIC2\0MIC BIAS2\0AMIC3\0MIC BIAS4\0AMIC4\0MIC BIAS1\0AMIC5\0MIC BIAS3";

