# Official global Ubuntu Ports mirror. Override at build time with
# RAZER_UBUNTU_MIRROR=https://your-nearby-mirror.example/ubuntu-ports
: "${RAZER_UBUNTU_MIRROR:=https://ports.ubuntu.com/ubuntu-ports}"

# The normal production image includes the 3D-printer stack. Supported values:
# base, printer
: "${RAZER_IMAGE_PROFILE:=printer}"
