diff --git a/drivers/remoteproc/qcom_q6v5_mss.c b/drivers/remoteproc/qcom_q6v5_mss.c
index d73f6f2c9c3a..f48b9dc60b27 100644
--- a/drivers/remoteproc/qcom_q6v5_mss.c
+++ b/drivers/remoteproc/qcom_q6v5_mss.c
@@ -258,6 +258,41 @@ enum {
 	MSS_SDM845,
 };
 
+static void q6v5_mss_crash_dump(struct qcom_q6v5 *q6v5, const char *reason)
+{
+	struct q6v5 *qproc = container_of(q6v5, struct q6v5, q6v5);
+	u32 image, pbl, command, mba_status, pmi_meta, pmi_start, pmi_len;
+	u32 mss_status, alt_reset;
+
+	/*
+	 * Keep this deliberately limited to the RMB window. Razer SDM845
+	 * post-fatal reads from qproc->reg_base or halt_map have previously
+	 * caused synchronous external aborts in the q6v5 IRQ thread.
+	 */
+	image = readl_relaxed(qproc->rmb_base + RMB_MBA_IMAGE_REG);
+	pbl = readl_relaxed(qproc->rmb_base + RMB_PBL_STATUS_REG);
+	command = readl_relaxed(qproc->rmb_base + RMB_MBA_COMMAND_REG);
+	mba_status = readl_relaxed(qproc->rmb_base + RMB_MBA_STATUS_REG);
+	pmi_meta = readl_relaxed(qproc->rmb_base + RMB_PMI_META_DATA_REG);
+	pmi_start = readl_relaxed(qproc->rmb_base + RMB_PMI_CODE_START_REG);
+	pmi_len = readl_relaxed(qproc->rmb_base + RMB_PMI_CODE_LENGTH_REG);
+	mss_status = readl_relaxed(qproc->rmb_base + RMB_MBA_MSS_STATUS);
+	alt_reset = readl_relaxed(qproc->rmb_base + RMB_MBA_ALT_RESET);
+
+	dev_emerg(qproc->dev,
+		  "mss rmb snapshot %s: image=0x%08x pbl=0x%08x cmd=0x%08x mba=0x%08x pmi_meta=0x%08x pmi_start=0x%08x pmi_len=0x%08x\n",
+		  reason, image, pbl, command, mba_status, pmi_meta, pmi_start,
+		  pmi_len);
+	dev_emerg(qproc->dev,
+		  "mss rmb snapshot %s: mss_status=0x%08x alt_reset=0x%08x mba_phys=%pa mba_size=0x%zx mpss_phys=%pa mpss_size=0x%zx\n",
+		  reason, mss_status, alt_reset, &qproc->mba_phys,
+		  qproc->mba_size, &qproc->mpss_phys, qproc->mpss_size);
+}
+
 static int q6v5_regulator_init(struct device *dev, struct reg_info *regs,
 			       const struct qcom_mss_reg_res *reg_res)
 {
@@ -2191,6 +2226,8 @@ static int q6v5_probe(struct platform_device *pdev)
 	if (ret)
 		goto detach_proxy_pds;
 
+	qproc->q6v5.crash_dump = q6v5_mss_crash_dump;
+
 	qproc->mpss_perm = BIT(QCOM_SCM_VMID_HLOS);
 	qproc->mba_perm = BIT(QCOM_SCM_VMID_HLOS);
 	qcom_add_glink_subdev(rproc, &qproc->glink_subdev, "mpss");
