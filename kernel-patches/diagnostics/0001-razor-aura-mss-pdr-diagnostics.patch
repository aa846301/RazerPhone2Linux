 static int q6v5_reset_deassert(struct q6v5 *qproc)
 {
-	int ret;
+	int ret, ret2;
 
 	if (qproc->has_alt_reset) {
-		reset_control_assert(qproc->pdc_reset);
+		dev_info(qproc->dev,
+			 "sdm845 mss diag reset: assert pdc, assert alt, pulse restart\n");
