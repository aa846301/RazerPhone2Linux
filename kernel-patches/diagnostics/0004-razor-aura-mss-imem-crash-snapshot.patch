+static bool razer_mss_imem_diag;
+static bool razer_mss_imem_diag_bootarg;
+module_param_named(razer_mss_imem_diag, razer_mss_imem_diag, bool, 0644);
+MODULE_PARM_DESC(razer_mss_imem_diag,
+		 "Dump SDM845 IMEM ranges on MSS fatal/watchdog for Razer aura diagnostics");
+
+static bool q6v5_mss_imem_diag_requested(void)
+{
+	return razer_mss_imem_diag || razer_mss_imem_diag_bootarg;
+}
+
+static bool q6v5_mss_parse_imem_diag_bootarg(void)
+{
+	struct device_node *chosen;
+	const char *bootargs = NULL;
+	bool enabled = false;
+
+	chosen = of_find_node_by_path("/chosen");
+	if (!chosen)
+		return false;
+
+	if (!of_property_read_string(chosen, "bootargs", &bootargs) &&
+	    bootargs) {
+		enabled = strstr(bootargs, "razer_mss_imem_diag=1") ||
+			  strstr(bootargs, "razer_mss_imem_diag=y") ||
+			  strstr(bootargs, "razer_mss_imem_diag=true") ||
+			  strstr(bootargs,
+				 "qcom_q6v5_mss.razer_mss_imem_diag=1");
+	}
+	of_node_put(chosen);
+
+	return enabled;
+}
+
+static void __iomem *q6v5_mss_map_imem(struct device *dev)
+{
+	struct device_node *np;
+	struct resource res;
+	void __iomem *base = NULL;
+
+	razer_mss_imem_diag_bootarg = q6v5_mss_parse_imem_diag_bootarg();
+
+	if (!q6v5_mss_imem_diag_requested())
+		return NULL;
+
+	np = of_find_compatible_node(NULL, NULL, "qcom,sdm845-imem");
+	if (np && !of_address_to_resource(np, 0, &res)) {
+		base = devm_ioremap(dev, res.start, resource_size(&res));
+		if (base)
+			dev_info(dev,
+				 "mss imem diag: mapped qcom,sdm845-imem at %pa size=0x%llx\n",
+				 &res.start, (unsigned long long)resource_size(&res));
+	}
+	of_node_put(np);
+
+	if (!base) {
+		base = devm_ioremap(dev, RAZER_MSS_IMEM_PHYS,
+				    RAZER_MSS_IMEM_SIZE);
+		if (base)
+			dev_info(dev,
+				 "mss imem diag: mapped fallback IMEM at 0x%x size=0x%x\n",
+				 RAZER_MSS_IMEM_PHYS, RAZER_MSS_IMEM_SIZE);
+	}
+
+	if (!base)
+		dev_err(dev, "mss imem diag: failed to map IMEM\n");
+
+	return base;
+}
+
+static void q6v5_mss_dump_imem_range(struct q6v5 *qproc, const char *reason,
+				     const char *name, u32 offset, u32 len)
+{
+	u32 pos;
+
+	if (!qproc->imem_base)
+		return;
+
+	if (offset >= RAZER_MSS_IMEM_SIZE)
+		return;
+
+	if (offset + len > RAZER_MSS_IMEM_SIZE)
+		len = RAZER_MSS_IMEM_SIZE - offset;
+
+	dev_emerg(qproc->dev,
+		  "mss imem snapshot %s: range=%s offset=0x%03x len=0x%x\n",
+		  reason, name, offset, len);
+
+	for (pos = 0; pos < len; pos += 16) {
+		u32 addr = offset + pos;
+		u32 w0 = readl_relaxed(qproc->imem_base + addr);
+		u32 w1 = 0;
+		u32 w2 = 0;
+		u32 w3 = 0;
+
+		if (pos + 4 < len)
+			w1 = readl_relaxed(qproc->imem_base + addr + 4);
+		if (pos + 8 < len)
+			w2 = readl_relaxed(qproc->imem_base + addr + 8);
+		if (pos + 12 < len)
+			w3 = readl_relaxed(qproc->imem_base + addr + 12);
+
+		dev_emerg(qproc->dev,
+			  "mss imem snapshot %s: %s+0x%03x: %08x %08x %08x %08x\n",
+			  reason, name, pos, w0, w1, w2, w3);
+	}
+}
+
+static void q6v5_mss_dump_imem(struct q6v5 *qproc, const char *reason)
+{
+	if (!q6v5_mss_imem_diag_requested())
+		return;
+
+	if (!qproc->imem_base) {
+		dev_emerg(qproc->dev,
+			  "mss imem snapshot %s: requested but IMEM is not mapped\n",
+			  reason);
+		return;
+	}
+
+	q6v5_mss_dump_imem_range(qproc, reason, "head", 0x000, 0x040);
+	q6v5_mss_dump_imem_range(qproc, reason, "dload_type",
+				 RAZER_MSS_IMEM_DLOAD_TYPE, 0x010);
+	q6v5_mss_dump_imem_range(qproc, reason, "diag_dload",
+				 RAZER_MSS_IMEM_DIAG_DLOAD, 0x0c8);
+	q6v5_mss_dump_imem_range(qproc, reason, "restart_reason",
+				 RAZER_MSS_IMEM_RESTART_REASON, 0x010);
+	q6v5_mss_dump_imem_range(qproc, reason, "boot_stats",
+				 RAZER_MSS_IMEM_BOOT_STATS, 0x020);
+	q6v5_mss_dump_imem_range(qproc, reason, "pil",
+				 RAZER_MSS_IMEM_PIL, 0x0c8);
+}
