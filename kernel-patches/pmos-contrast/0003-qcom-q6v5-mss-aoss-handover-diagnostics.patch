diff --git a/drivers/remoteproc/qcom_q6v5.c b/drivers/remoteproc/qcom_q6v5.c
index e13806c32..444444444 100644
--- a/drivers/remoteproc/qcom_q6v5.c
+++ b/drivers/remoteproc/qcom_q6v5.c
@@ -24,13 +24,22 @@ static int q6v5_load_state_toggle(struct qcom_q6v5 *q6v5, bool enable)
 {
 	int ret;
 
-	if (!q6v5->qmp)
+	if (!q6v5->qmp) {
+		dev_info_once(q6v5->dev,
+			      "q6v5 diag: no AOSS QMP load_state handle\n");
 		return 0;
+	}
+
+	dev_info(q6v5->dev, "q6v5 diag: AOSS load_state %s -> %s\n",
+		 q6v5->load_state ?: "(null)", enable ? "on" : "off");
 
 	ret = qmp_send(q6v5->qmp, "{class: image, res: load_state, name: %s, val: %s}",
 		       q6v5->load_state, enable ? "on" : "off");
 	if (ret)
-		dev_err(q6v5->dev, "failed to toggle load state\n");
+		dev_err(q6v5->dev, "failed to toggle load state: %d\n", ret);
+	else
+		dev_info(q6v5->dev, "q6v5 diag: AOSS load_state acknowledged\n");
 
 	return ret;
 }
@@ -57,12 +66,16 @@ int qcom_q6v5_prepare(struct qcom_q6v5 *q6v5)
 		return ret;
 	}
 
+	dev_info(q6v5->dev, "q6v5 diag: prepare enable load_state\n");
 	ret = q6v5_load_state_toggle(q6v5, true);
 	if (ret) {
 		icc_set_bw(q6v5->path, 0, 0);
 		return ret;
 	}
 
+	dev_info(q6v5->dev,
+		 "q6v5 diag: prepare reinit start/stop completions and enable handover irq\n");
+
 	reinit_completion(&q6v5->start_done);
 	reinit_completion(&q6v5->stop_done);
 
@@ -79,6 +92,7 @@ EXPORT_SYMBOL_GPL(qcom_q6v5_prepare);
  */
 int qcom_q6v5_unprepare(struct qcom_q6v5 *q6v5)
 {
+	dev_info(q6v5->dev, "q6v5 diag: unprepare disable handover irq and load_state\n");
 	disable_irq(q6v5->handover_irq);
 	q6v5_load_state_toggle(q6v5, false);
 
@@ -220,8 +234,12 @@ static irqreturn_t q6v5_handover_interrupt(int irq, void *data)
 {
 	struct qcom_q6v5 *q6v5 = data;
 
-	if (q6v5->handover)
+	dev_info(q6v5->dev, "q6v5 diag: handover interrupt received\n");
+	if (q6v5->handover) {
+		dev_info(q6v5->dev, "q6v5 diag: calling handover callback\n");
 		q6v5->handover(q6v5);
+	}
 
 	icc_set_bw(q6v5->path, 0, 0);
 
