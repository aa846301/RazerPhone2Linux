From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Razer Phone 2 Linux Port <razerphone2linux@example.invalid>
Date: Wed, 17 Jun 2026 14:40:00 +0800
Subject: [PATCH] net: ipa: add Razer IPA QMI handshake diagnostics

Android logs show a successful IPA modem init request/response before the
WLAN protection domain appears.  The Razer mainline bring-up reaches the IPA
"modem running" event but MSS fatals before WLFW/service 69.  Add
observational IPA QMI logs around the AP<->modem handshake so a controlled
Linux boot can prove whether INIT_DRIVER is sent, whether the modem answers,
and whether DRIVER_INIT_COMPLETE/INDICATION_REGISTER arrive before the MSS
fatal.

This patch is intentionally diagnostic only.
---
 drivers/net/ipa/ipa_qmi.c | 143 ++++++++++++++++++++++++++++++++++++--
 1 file changed, 137 insertions(+), 6 deletions(-)

diff --git a/drivers/net/ipa/ipa_qmi.c b/drivers/net/ipa/ipa_qmi.c
--- a/drivers/net/ipa/ipa_qmi.c
+++ b/drivers/net/ipa/ipa_qmi.c
@@ -89,13 +89,29 @@ static void ipa_server_init_complete(struct ipa_qmi *ipa_qmi)
 	ind.status.result = QMI_RESULT_SUCCESS_V01;
 	ind.status.error = QMI_ERR_NONE_V01;
 
+	dev_info(ipa->dev,
+		 "IPA QMI diag: sending INIT_COMPLETE indication node=%u port=%u modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+		 sq->sq_node, sq->sq_port, ipa_qmi->modem_ready,
+		 ipa_qmi->uc_ready, ipa_qmi->indication_requested,
+		 ipa_qmi->indication_sent, ipa_qmi->initial_boot);
+
 	ret = qmi_send_indication(qmi, sq, IPA_QMI_INIT_COMPLETE,
 				   IPA_QMI_INIT_COMPLETE_IND_SZ,
 				   ipa_init_complete_ind_ei, &ind);
-	if (ret)
+	if (ret) {
 		dev_err(ipa->dev,
 			"error %d sending init complete indication\n", ret);
-	else
+		dev_err(ipa->dev,
+			"IPA QMI diag: INIT_COMPLETE indication failed ret=%d\n",
+			ret);
+	} else {
 		ipa_qmi->indication_sent = true;
+		dev_info(ipa->dev,
+			 "IPA QMI diag: INIT_COMPLETE indication sent modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+			 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+			 ipa_qmi->indication_requested,
+			 ipa_qmi->indication_sent,
+			 ipa_qmi->initial_boot);
+	}
 }
 
 /* If requested (and not already sent) send the INIT_COMPLETE indication */
@@ -119,13 +135,19 @@ static void ipa_qmi_indication(struct ipa_qmi *ipa_qmi)
  */
 static void ipa_qmi_ready(struct ipa_qmi *ipa_qmi)
 {
-	struct ipa *ipa;
+	struct ipa *ipa = container_of(ipa_qmi, struct ipa, qmi);
 	int ret;
 
 	/* We aren't ready until the modem and microcontroller are */
-	if (!ipa_qmi->modem_ready || !ipa_qmi->uc_ready)
+	if (!ipa_qmi->modem_ready || !ipa_qmi->uc_ready) {
+		dev_info(ipa->dev,
+			 "IPA QMI diag: not ready modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+			 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+			 ipa_qmi->indication_requested,
+			 ipa_qmi->indication_sent,
+			 ipa_qmi->initial_boot);
 		return;
+	}
 
 	/* Send the indication message if it was requested */
 	ipa_qmi_indication(ipa_qmi);
@@ -133,16 +155,26 @@ static void ipa_qmi_ready(struct ipa_qmi *ipa_qmi)
 	/* The initial boot requires us to send the indication. */
 	if (ipa_qmi->initial_boot) {
 		if (!ipa_qmi->indication_sent)
+			dev_info(ipa->dev,
+				 "IPA QMI diag: waiting for INIT_COMPLETE indication modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+				 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+				 ipa_qmi->indication_requested,
+				 ipa_qmi->indication_sent,
+				 ipa_qmi->initial_boot);
+		if (!ipa_qmi->indication_sent)
 			return;
 
 		/* The initial modem boot completed successfully */
 		ipa_qmi->initial_boot = false;
+		dev_info(ipa->dev,
+			 "IPA QMI diag: initial IPA QMI handshake complete\n");
 	}
 
 	/* We're ready.  Start up normal operation */
-	ipa = container_of(ipa_qmi, struct ipa, qmi);
+	dev_info(ipa->dev,
+		 "IPA QMI diag: starting IPA modem path modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+		 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+		 ipa_qmi->indication_requested, ipa_qmi->indication_sent,
+		 ipa_qmi->initial_boot);
 	ret = ipa_modem_start(ipa);
 	if (ret)
 		dev_err(ipa->dev, "error %d starting modem\n", ret);
@@ -151,10 +183,16 @@ static void ipa_qmi_ready(struct ipa_qmi *ipa_qmi)
 /* All QMI clients from the modem node are gone (modem shut down or crashed). */
 static void ipa_server_bye(struct qmi_handle *qmi, unsigned int node)
 {
 	struct ipa_qmi *ipa_qmi;
+	struct ipa *ipa;
 
 	ipa_qmi = container_of(qmi, struct ipa_qmi, server_handle);
+	ipa = container_of(ipa_qmi, struct ipa, qmi);
 
 	/* The modem client and server go away at the same time */
+	dev_info(ipa->dev,
+		 "IPA QMI diag: modem server bye node=%u modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+		 node, ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+		 ipa_qmi->indication_requested, ipa_qmi->indication_sent,
+		 ipa_qmi->initial_boot);
 	memset(&ipa_qmi->modem_sq, 0, sizeof(ipa_qmi->modem_sq));
 
 	/* initial_boot doesn't change when modem reboots */
@@ -176,6 +214,7 @@ static void ipa_server_indication_register(struct qmi_handle *qmi,
 					   struct qmi_txn *txn,
 					   const void *decoded)
 {
+	const struct ipa_indication_register_req *req = decoded;
 	struct ipa_indication_register_rsp rsp = { };
 	struct ipa_qmi *ipa_qmi;
 	struct ipa *ipa;
@@ -185,6 +224,15 @@ static void ipa_server_indication_register(struct qmi_handle *qmi,
 	ipa_qmi = container_of(qmi, struct ipa_qmi, server_handle);
 	ipa = container_of(ipa_qmi, struct ipa, qmi);
 
+	dev_info(ipa->dev,
+		 "IPA QMI diag: INDICATION_REGISTER request node=%u port=%u master_valid=%u master=%u quota_valid=%u quota=%u mhi_valid=%u mhi=%u ep_valid=%u ep=%u bw_valid=%u bw=%u\n",
+		 sq->sq_node, sq->sq_port,
+		 req->master_driver_init_complete_valid,
+		 req->master_driver_init_complete,
+		 req->data_usage_quota_reached_valid,
+		 req->data_usage_quota_reached, req->ipa_mhi_ready_ind_valid,
+		 req->ipa_mhi_ready_ind, req->endpoint_desc_ind_valid,
+		 req->endpoint_desc_ind, req->bw_change_ind_valid,
+		 req->bw_change_ind);
+
 	rsp.rsp.result = QMI_RESULT_SUCCESS_V01;
 	rsp.rsp.error = QMI_ERR_NONE_V01;
 
@@ -194,6 +242,10 @@ static void ipa_server_indication_register(struct qmi_handle *qmi,
 				ipa_indication_register_rsp_ei, &rsp);
 	if (!ret) {
 		ipa_qmi->indication_requested = true;
+		dev_info(ipa->dev,
+			 "IPA QMI diag: INDICATION_REGISTER response sent modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+			 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+			 ipa_qmi->indication_requested, ipa_qmi->indication_sent,
+			 ipa_qmi->initial_boot);
 		ipa_qmi_ready(ipa_qmi);		/* We might be ready now */
 	} else {
 		dev_err(ipa->dev,
@@ -207,6 +259,7 @@ static void ipa_server_driver_init_complete(struct qmi_handle *qmi,
 					    struct qmi_txn *txn,
 					    const void *decoded)
 {
+	const struct ipa_driver_init_complete_req *req = decoded;
 	struct ipa_driver_init_complete_rsp rsp = { };
 	struct ipa_qmi *ipa_qmi;
 	struct ipa *ipa;
@@ -216,6 +269,10 @@ static void ipa_server_driver_init_complete(struct qmi_handle *qmi,
 	ipa_qmi = container_of(qmi, struct ipa_qmi, server_handle);
 	ipa = container_of(ipa_qmi, struct ipa, qmi);
 
+	dev_info(ipa->dev,
+		 "IPA QMI diag: DRIVER_INIT_COMPLETE request node=%u port=%u status=%u\n",
+		 sq->sq_node, sq->sq_port, req->status);
+
 	rsp.rsp.result = QMI_RESULT_SUCCESS_V01;
 	rsp.rsp.error = QMI_ERR_NONE_V01;
 
@@ -225,6 +282,10 @@ static void ipa_server_driver_init_complete(struct qmi_handle *qmi,
 				ipa_driver_init_complete_rsp_ei, &rsp);
 	if (!ret) {
 		ipa_qmi->uc_ready = true;
+		dev_info(ipa->dev,
+			 "IPA QMI diag: DRIVER_INIT_COMPLETE response sent modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+			 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+			 ipa_qmi->indication_requested, ipa_qmi->indication_sent,
+			 ipa_qmi->initial_boot);
 		ipa_qmi_ready(ipa_qmi);		/* We might be ready now */
 	} else {
 		dev_err(ipa->dev,
@@ -254,6 +315,22 @@ static void ipa_client_init_driver(struct qmi_handle *qmi,
 				   struct sockaddr_qrtr *sq,
 				   struct qmi_txn *txn, const void *decoded)
 {
+	const struct ipa_init_modem_driver_rsp *rsp = decoded;
+	struct ipa_qmi *ipa_qmi;
+	struct ipa *ipa;
+
+	ipa_qmi = container_of(qmi, struct ipa_qmi, client_handle);
+	ipa = container_of(ipa_qmi, struct ipa, qmi);
+
+	dev_info(ipa->dev,
+		 "IPA QMI diag: INIT_DRIVER response node=%u port=%u result=%u error=%u ctrl_valid=%u ctrl_ep=%u default_valid=%u default_ep=%u pending_valid=%u pending=%u\n",
+		 sq->sq_node, sq->sq_port, rsp->rsp.result, rsp->rsp.error,
+		 rsp->ctrl_comm_dest_end_pt_valid,
+		 rsp->ctrl_comm_dest_end_pt,
+		 rsp->default_end_pt_valid,
+		 rsp->default_end_pt,
+		 rsp->modem_driver_init_pending_valid,
+		 rsp->modem_driver_init_pending);
+
 	txn->result = 0;	/* IPA_QMI_INIT_DRIVER request was successful */
 	complete(&txn->completion);
 }
@@ -426,17 +503,53 @@ static void ipa_client_init_driver_work(struct work_struct *work)
 
 	/* Send the request, and if successful wait for its response */
 	req = init_modem_driver_req(ipa_qmi);
+	dev_info(dev,
+		 "IPA QMI diag: sending INIT_DRIVER node=%u port=%u uc_loaded=%u modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u skip_uc_load=%u ctrl_ep_valid=%u ctrl_ep=%u modem_mem_valid=%u modem_mem_start=0x%08x modem_mem_size=0x%08x\n",
+		 ipa_qmi->modem_sq.sq_node, ipa_qmi->modem_sq.sq_port,
+		 ipa->uc_loaded, ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+		 ipa_qmi->indication_requested, ipa_qmi->indication_sent,
+		 ipa_qmi->initial_boot, req->skip_uc_load,
+		 req->ctrl_comm_dest_end_pt_valid,
+		 req->ctrl_comm_dest_end_pt, req->modem_mem_info_valid,
+		 req->modem_mem_info.start, req->modem_mem_info.size);
+	dev_info(dev,
+		 "IPA QMI diag: INIT_DRIVER tables hdr_valid=%u hdr=0x%08x-0x%08x v4_route_valid=%u v4_route=0x%08x-%u v6_route_valid=%u v6_route=0x%08x-%u v4_filter_valid=%u v4_filter=0x%08x v6_filter_valid=%u v6_filter=0x%08x\n",
+		 req->hdr_tbl_info_valid, req->hdr_tbl_info.start,
+		 req->hdr_tbl_info.end, req->v4_route_tbl_info_valid,
+		 req->v4_route_tbl_info.start, req->v4_route_tbl_info.end,
+		 req->v6_route_tbl_info_valid, req->v6_route_tbl_info.start,
+		 req->v6_route_tbl_info.end, req->v4_filter_tbl_start_valid,
+		 req->v4_filter_tbl_start, req->v6_filter_tbl_start_valid,
+		 req->v6_filter_tbl_start);
+
 	ret = qmi_send_request(qmi, &ipa_qmi->modem_sq, &txn,
 			       IPA_QMI_INIT_DRIVER, IPA_QMI_INIT_DRIVER_REQ_SZ,
 			       ipa_init_modem_driver_req_ei, req);
-	if (ret)
+	if (ret) {
 		dev_err(dev, "error %d sending init driver request\n", ret);
-	else if ((ret = qmi_txn_wait(&txn, timeout)))
+		dev_err(dev,
+			"IPA QMI diag: INIT_DRIVER send failed ret=%d node=%u port=%u\n",
+			ret, ipa_qmi->modem_sq.sq_node,
+			ipa_qmi->modem_sq.sq_port);
+	} else {
+		dev_info(dev,
+			 "IPA QMI diag: INIT_DRIVER request sent, waiting up to %u ms\n",
+			 QMI_INIT_DRIVER_TIMEOUT);
+		ret = qmi_txn_wait(&txn, timeout);
+		if (ret)
+			dev_err(dev,
+				"error %d awaiting init driver response\n",
+				ret);
+		else
+			dev_info(dev,
+				 "IPA QMI diag: INIT_DRIVER transaction complete\n");
+	}
+
+	if (ret)
 		dev_err(dev, "error %d awaiting init driver response\n", ret);
 
 	if (!ret) {
 		ipa_qmi->modem_ready = true;
+		dev_info(dev,
+			 "IPA QMI diag: modem_ready set modem_ready=%u uc_ready=%u indication_requested=%u indication_sent=%u initial_boot=%u\n",
+			 ipa_qmi->modem_ready, ipa_qmi->uc_ready,
+			 ipa_qmi->indication_requested, ipa_qmi->indication_sent,
+			 ipa_qmi->initial_boot);
 		ipa_qmi_ready(ipa_qmi);		/* We might be ready now */
 	} else {
 		/* If any error occurs we need to cancel the transaction */
@@ -450,6 +563,7 @@ ipa_client_new_server(struct qmi_handle *qmi, struct qmi_service *svc)
 {
 	struct ipa_qmi *ipa_qmi;
+	struct ipa *ipa;
 
 	ipa_qmi = container_of(qmi, struct ipa_qmi, client_handle);
+	ipa = container_of(ipa_qmi, struct ipa, qmi);
 
 	ipa_qmi->modem_sq.sq_family = AF_QIPCRTR;
 	ipa_qmi->modem_sq.sq_node = svc->node;
 	ipa_qmi->modem_sq.sq_port = svc->port;
 
+	dev_info(ipa->dev,
+		 "IPA QMI diag: modem IPA service discovered node=%u port=%u scheduling INIT_DRIVER\n",
+		 svc->node, svc->port);
+
 	schedule_work(&ipa_qmi->init_driver_work);
 
 	return 0;
@@ -471,6 +585,10 @@ int ipa_qmi_setup(struct ipa *ipa)
 
 	ipa_qmi->initial_boot = true;
 
+	dev_info(ipa->dev,
+		 "IPA QMI diag: setup host_svc=%u/%u/%u modem_svc=%u/%u/%u\n",
+		 IPA_HOST_SERVICE_SVC_ID, IPA_HOST_SVC_VERS,
+		 IPA_HOST_SERVICE_INS_ID, IPA_MODEM_SERVICE_SVC_ID,
+		 IPA_MODEM_SVC_VERS, IPA_MODEM_SERVICE_INS_ID);
+
 	/* The server handle is used to handle the DRIVER_INIT_COMPLETE
 	 * request on the first modem boot.  It also receives the
 	 * INDICATION_REGISTER request on the first boot and (optionally)
@@ -485,6 +603,9 @@ int ipa_qmi_setup(struct ipa *ipa)
 	ret = qmi_add_server(&ipa_qmi->server_handle, IPA_HOST_SERVICE_SVC_ID,
 			     IPA_HOST_SVC_VERS, IPA_HOST_SERVICE_INS_ID);
 	if (ret)
 		goto err_server_handle_release;
+	dev_info(ipa->dev,
+		 "IPA QMI diag: host IPA QMI server registered ret=%d\n",
+		 ret);
 
 	/* The client handle is only used for sending an INIT_DRIVER request
 	 * to the modem, and receiving its response message.
@@ -503,6 +624,9 @@ int ipa_qmi_setup(struct ipa *ipa)
 	ret = qmi_add_lookup(&ipa_qmi->client_handle, IPA_MODEM_SERVICE_SVC_ID,
 			     IPA_MODEM_SVC_VERS, IPA_MODEM_SERVICE_INS_ID);
 	if (ret)
 		goto err_client_handle_release;
+	dev_info(ipa->dev,
+		 "IPA QMI diag: modem IPA QMI lookup registered ret=%d\n",
+		 ret);
 
 	return 0;
 
