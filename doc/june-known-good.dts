							reg = <0x01>;
						};

						dai@2 {
							reg = <0x02>;
						};

						dai@3 {
							reg = <0x03>;
						};
					};
				};

				service@8 {
					compatible = "qcom,q6adm";
					reg = <0x08>;
					qcom,protection-domain = "avs/audio\0msm/adsp/audio_pd";

					routing {
						compatible = "qcom,q6adm-routing";
						#sound-dai-cells = <0x00>;
						phandle = <0x103>;
					};
