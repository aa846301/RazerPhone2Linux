diff --git a/drivers/remoteproc/qcom_sysmon.c b/drivers/remoteproc/qcom_sysmon.c
index 11abcc6f4243..48c5dd809f1c 100644
--- a/drivers/remoteproc/qcom_sysmon.c
+++ b/drivers/remoteproc/qcom_sysmon.c
@@ -380,6 +380,10 @@ static void ssctl_send_event(struct qcom_sysmon *sysmon,
 	struct qmi_txn txn;
 	int ret;
 
+	dev_info(sysmon->dev, "sysmon diag: ssctl event to %s peer=%s state=%s\n",
+		 sysmon->name, event->subsys_name,
+		 sysmon_state_string[event->ssr_event]);
+
 	memset(&resp, 0, sizeof(resp));
 	ret = qmi_txn_init(&sysmon->qmi, &txn, ssctl_subsys_event_resp_ei, &resp);
 	if (ret < 0) {
@@ -405,7 +409,8 @@ static void ssctl_send_event(struct qcom_sysmon *sysmon,
 	else if (resp.resp.result)
 		dev_err(sysmon->dev, "subsystem event rejected\n");
 	else
-		dev_dbg(sysmon->dev, "subsystem event accepted\n");
+		dev_info(sysmon->dev, "sysmon diag: ssctl event accepted for peer=%s state=%s\n",
+			 event->subsys_name, sysmon_state_string[event->ssr_event]);
 }
 
 /**
@@ -443,6 +448,10 @@ static int ssctl_new_server(struct qmi_handle *qmi, struct qmi_service *svc)
 	sysmon->ssctl.sq_node = svc->node;
 	sysmon->ssctl.sq_port = svc->port;
 
+	dev_info(sysmon->dev,
+		 "sysmon diag: ssctl server name=%s version=%u instance=%u node=%u port=%u\n",
+		 sysmon->name, svc->version, svc->instance, svc->node, svc->port);
+
 	svc->priv = sysmon;
 
 	complete(&sysmon->ssctl_comp);
@@ -506,6 +515,9 @@ static int sysmon_start(struct rproc_subdev *subdev)
 	sysmon->state = SSCTL_SSR_EVENT_AFTER_POWERUP;
 	blocking_notifier_call_chain(&sysmon_notifiers, 0, (void *)&event);
 	mutex_unlock(&sysmon->state_lock);
+	dev_info(sysmon->dev,
+		 "sysmon diag: start name=%s ssctl_version=%d ssctl_instance=%d\n",
+		 sysmon->name, sysmon->ssctl_version, sysmon->ssctl_instance);
 
 	mutex_lock(&sysmon_lock);
 	list_for_each_entry(target, &sysmon_list, node) {
@@ -519,6 +531,17 @@ static int sysmon_start(struct rproc_subdev *subdev)
 		event.subsys_name = target->name;
 		event.ssr_event = target->state;
 
+		if (!strcmp(sysmon->name, "modem")) {
+			/*
+			 * Razer aura MSS currently fatal-errors immediately after
+			 * modem-up and service-registry lookup, before WLFW
+			 * appears. Test whether peer SSR notifications are the
+			 * trigger before changing firmware, rmtfs, or WiFi DTS.
+			 */
+			dev_info(sysmon->dev, "sysmon diag: skip modem peer event %s state=%s\n",
+				 event.subsys_name, sysmon_state_string[event.ssr_event]);
+			mutex_unlock(&target->state_lock);
+			continue;
+		}
 		if (sysmon->ssctl_version == 2)
 			ssctl_send_event(sysmon, &event);
 		else if (sysmon->ept)
@@ -591,6 +614,17 @@ static int sysmon_notify(struct notifier_block *nb, unsigned long event,
 		return NOTIFY_DONE;
 	}
 
+	if (!strcmp(sysmon_event->subsys_name, "modem")) {
+		/*
+		 * Complete the sysmon isolation test: do not notify ADSP/CDSP/SLPI
+		 * about modem before/after power-up either. If MSS still fatal-errors,
+		 * sysmon peer SSR notifications are not the immediate trigger.
+		 */
+		dev_info(sysmon->dev, "sysmon diag: skip peer notification target=%s peer=modem state=%s\n",
+			 sysmon->name, sysmon_state_string[sysmon_event->ssr_event]);
+		return NOTIFY_DONE;
+	}
+
 	/* Only SSCTL version 2 supports SSR events */
 	if (sysmon->ssctl_version == 2)
 		ssctl_send_event(sysmon, sysmon_event);
