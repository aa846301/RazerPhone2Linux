# Additional kernel features for using the phone as a Klipper host.
CONFIG_LOCALVERSION="-sdm845-printer"

# Lower scheduling latency and accurate host timing.
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set
CONFIG_HZ_250=y
# CONFIG_HZ_100 is not set
# CONFIG_HZ_1000 is not set

# CAN/CAN-FD adapters commonly used by Klipper toolheads.
CONFIG_CAN=m
CONFIG_CAN_RAW=m
CONFIG_CAN_BCM=m
CONFIG_CAN_GW=m
CONFIG_CAN_DEV=m
CONFIG_CAN_NETLINK=y
CONFIG_CAN_CALC_BITTIMING=y
CONFIG_CAN_RX_OFFLOAD=y
CONFIG_CAN_GS_USB=m
CONFIG_CAN_KVASER_USB=m
CONFIG_CAN_PEAK_USB=m
CONFIG_CAN_8DEV_USB=m
CONFIG_CAN_M_CAN=m
CONFIG_CAN_MCP251X=m
CONFIG_CAN_MCP251XFD=m

# Common USB serial bridges used by printer control boards.
CONFIG_USB_SERIAL_CH341=m
CONFIG_USB_SERIAL_CP210X=m
CONFIG_USB_SERIAL_FTDI_SIO=m
CONFIG_USB_SERIAL_PL2303=m
# USB host networking and OTG-attached adapters.
CONFIG_USB_USBNET=m
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_NET_CDCETHER=m
CONFIG_USB_NET_CDC_NCM=m
CONFIG_USB_NET_RNDIS_HOST=m

# User-visible hardware interfaces useful for printer accessories.
CONFIG_I2C_CHARDEV=m
CONFIG_SPI_SPIDEV=m
CONFIG_GPIO_CDEV=y
CONFIG_PWM_SYSFS=y
CONFIG_HWMON=y
