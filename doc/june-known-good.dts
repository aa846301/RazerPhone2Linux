	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x01 0x08 0x01 0x02 0x08 0x01 0x03 0x08 0x01 0x00 0x08>;
	};

	gpio-keys {
		compatible = "gpio-keys";
		label = "Volume keys";
		autorepeat;
		pinctrl-names = "default";
		pinctrl-0 = <0x10a 0x10b>;

		key-vol-down {
			label = "Volume down";
			linux,code = <0x72>;
			gpios = <0xee 0x05 0x01>;
			debounce-interval = <0x0f>;
		};

		key-vol-up {
			label = "Volume up";
			linux,code = <0x73>;
			gpios = <0xee 0x06 0x01>;
			debounce-interval = <0x0f>;
		};
	};

	battery {
		compatible = "simple-battery";
		charge-full-design-microamp-hours = "\0=\t";
		voltage-min-design-microvolt = <0x33e140>;
		voltage-max-design-microvolt = <0x401640>;
		constant-charge-current-max-microamp = <0x1e8480>;
		phandle = <0xf0>;
	};

	vph-pwr-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vph_pwr";
		regulator-min-microvolt = <0x387520>;
		regulator-max-microvolt = <0x387520>;
		phandle = <0xf4>;
	};

	pm8998-smps4 {
		compatible = "regulator-fixed";
		regulator-name = "vreg_s4a_1p8";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <0xf4>;
		phandle = <0x54>;
	};

	ts-1p8-regulator {
		compatible = "regulator-fixed";
		regulator-name = "ts_1p8_supply";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		gpio = <0x70 0x58 0x00>;
		enable-active-high;
		phandle = <0x73>;
	};

	panel-vci-3v3-regulator {
		compatible = "regulator-fixed";
		regulator-name = "LCD_VCI_3V";
		regulator-min-microvolt = <0x325aa0>;
		regulator-max-microvolt = <0x325aa0>;
		gpio = <0x70 0x1a 0x00>;
		enable-active-high;
		pinctrl-0 = <0x10c>;
		pinctrl-names = "default";
		regulator-boot-on;
		regulator-always-on;
		phandle = <0xde>;
	};

	panel-vddi-poc-regulator {
		compatible = "regulator-fixed";
		regulator-name = "VDDI_POC";
		regulator-min-microvolt = <0x1b7740>;
		regulator-max-microvolt = <0x1b7740>;
		gpio = <0x70 0x19 0x00>;
		enable-active-high;
		pinctrl-0 = <0x10d>;
		pinctrl-names = "default";
		regulator-boot-on;
		regulator-always-on;
		phandle = <0xdf>;
	};
};
