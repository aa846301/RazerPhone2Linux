			platform {
				sound-dai = <0x103>;
			};
		};

		slim-dai-link {
			link-name = "SLIM Playback 1";

			cpu {
				sound-dai = <0x102 0x02>;
			};

			platform {
				sound-dai = <0x103>;
			};

			codec {
				sound-dai = <0xb9 0x00>;
			};
		};

		slimcap-dai-link {
			link-name = "SLIM Capture 1";

			cpu {
				sound-dai = <0x102 0x03>;
			};

			platform {
				sound-dai = <0x103>;
			};

			codec {
				sound-dai = <0xb9 0x01>;
			};
		};
	};

