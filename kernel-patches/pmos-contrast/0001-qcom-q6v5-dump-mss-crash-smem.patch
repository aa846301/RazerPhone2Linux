--- a/drivers/remoteproc/qcom_q6v5.c
+++ b/drivers/remoteproc/qcom_q6v5.c
@@ -79,6 +79,51 @@ int qcom_q6v5_unprepare(struct qcom_q6v5 *q6v5)
 }
 EXPORT_SYMBOL_GPL(qcom_q6v5_unprepare);
 
+static void q6v5_diag_dump_smem_item(struct qcom_q6v5 *q6v5,
+				     const char *reason, int host, int item)
+{
+	size_t len = 0;
+	u8 *msg;
+	size_t dump_len;
+
+	msg = qcom_smem_get(host, item, &len);
+	if (IS_ERR(msg)) {
+		dev_err(q6v5->dev,
+			"q6v5 diag %s: smem host=%d item=%d err=%ld\n",
+			reason, host, item, PTR_ERR(msg));
+		return;
+	}
+
+	if (!len) {
+		dev_err(q6v5->dev,
+			"q6v5 diag %s: smem host=%d item=%d len=0\n",
+			reason, host, item);
+		return;
+	}
+
+	dump_len = min_t(size_t, len, 64);
+	dev_err(q6v5->dev,
+		"q6v5 diag %s: smem host=%d item=%d len=%zu first64=%*ph\n",
+		reason, host, item, len, (int)dump_len, msg);
+
+	if (msg[0])
+		dev_err(q6v5->dev,
+			"q6v5 diag %s: smem host=%d item=%d text=\"%.*s\"\n",
+			reason, host, item, (int)dump_len, msg);
+}
+
+static void q6v5_diag_dump_crash_smem(struct qcom_q6v5 *q6v5,
+				      const char *reason)
+{
+	/*
+	 * MPSS crash reason is item 421. Dump both global and modem-private
+	 * host views, then item 6 as a low-cost sanity check. The goal is to
+	 * prove whether firmware wrote anything at fatal IRQ time.
+	 */
+	q6v5_diag_dump_smem_item(q6v5, reason, QCOM_SMEM_HOST_ANY,
+				 q6v5->crash_reason);
+	q6v5_diag_dump_smem_item(q6v5, reason, 1, q6v5->crash_reason);
+	q6v5_diag_dump_smem_item(q6v5, reason, QCOM_SMEM_HOST_ANY, 6);
+	q6v5_diag_dump_smem_item(q6v5, reason, 1, 6);
+}
+
 static irqreturn_t q6v5_wdog_interrupt(int irq, void *data)
 {
 	struct qcom_q6v5 *q6v5 = data;
@@ -101,6 +146,8 @@ static irqreturn_t q6v5_wdog_interrupt(int irq, void *data)
 	else
 		dev_err(q6v5->dev, "watchdog without message\n");
 
+	q6v5_diag_dump_crash_smem(q6v5, "watchdog");
+
 	q6v5->running = false;
 	rproc_report_crash(q6v5->rproc, RPROC_WATCHDOG);
 
@@ -123,6 +170,8 @@ static irqreturn_t q6v5_fatal_interrupt(int irq, void *data)
 	else
 		dev_err(q6v5->dev, "fatal error without message\n");
 
+	q6v5_diag_dump_crash_smem(q6v5, "fatal");
+
 	q6v5->running = false;
 	rproc_report_crash(q6v5->rproc, RPROC_FATAL_ERROR);
 
