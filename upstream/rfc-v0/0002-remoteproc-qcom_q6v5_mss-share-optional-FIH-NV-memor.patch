From 09eddb08265191519aeae5c66dba0e39cfe512d7 Mon Sep 17 00:00:00 2001
From: "dino.chang" <dino.chang@cimforce.com>
Date: Mon, 22 Jun 2026 14:59:18 +0800
Subject: [PATCH 2/3] remoteproc: qcom_q6v5_mss: share optional FIH NV memory

Share the optional Razer/FIH NV reserved-memory region with MSS.

The DT ABI still requires maintainer review and documentation.

Assisted-by: Codex:gpt-5
---
 drivers/remoteproc/qcom_q6v5_mss.c | 61 ++++++++++++++++++++++++++++++
 1 file changed, 61 insertions(+)

diff --git a/drivers/remoteproc/qcom_q6v5_mss.c b/drivers/remoteproc/qcom_q6v5_mss.c
index 0c0199fb0e68..a0aec5daf59d 100644
--- a/drivers/remoteproc/qcom_q6v5_mss.c
+++ b/drivers/remoteproc/qcom_q6v5_mss.c
@@ -233,6 +233,10 @@ struct q6v5 {
 	phys_addr_t mpss_reloc;
 	size_t mpss_size;
 
+	phys_addr_t fih_nv_phys;
+	size_t fih_nv_size;
+	u64 fih_nv_perm;
+
 	struct qcom_rproc_glink glink_subdev;
 	struct qcom_rproc_subdev smd_subdev;
 	struct qcom_rproc_pdm pdm_subdev;
@@ -483,6 +487,33 @@ static int q6v5_xfer_mem_ownership(struct q6v5 *qproc, u64 *current_perm,
 				   current_perm, next, perms);
 }
 
+static int q6v5_share_fih_nv(struct q6v5 *qproc)
+{
+	struct qcom_scm_vmperm next[2] = {
+		{
+			.vmid = QCOM_SCM_VMID_HLOS,
+			.perm = QCOM_SCM_PERM_RW,
+		},
+		{
+			.vmid = QCOM_SCM_VMID_MSS_MSA,
+			.perm = QCOM_SCM_PERM_RW,
+		},
+	};
+	u64 shared_perm = BIT(QCOM_SCM_VMID_HLOS) |
+			  BIT(QCOM_SCM_VMID_MSS_MSA);
+
+	if (!qproc->fih_nv_size || !qproc->need_mem_protection)
+		return 0;
+
+	if (qproc->fih_nv_perm == shared_perm)
+		return 0;
+
+	return qcom_scm_assign_mem(qproc->fih_nv_phys,
+				   ALIGN(qproc->fih_nv_size, SZ_4K),
+				   &qproc->fih_nv_perm, next,
+				   ARRAY_SIZE(next));
+}
+
 static void q6v5_debug_policy_load(struct q6v5 *qproc, void *mba_region)
 {
 	const struct firmware *dp_fw;
@@ -1112,6 +1143,10 @@ static int q6v5_mba_load(struct q6v5 *qproc)
 	int xfermemop_ret;
 	bool mba_load_err = false;
 
+	ret = q6v5_share_fih_nv(qproc);
+	if (ret)
+		return ret;
+
 	ret = qcom_q6v5_prepare(&qproc->q6v5);
 	if (ret)
 		return ret;
@@ -2039,6 +2074,28 @@ static int q6v5_alloc_memory_region(struct q6v5 *qproc)
 	return 0;
 }
 
+static int q6v5_alloc_fih_nv_region(struct q6v5 *qproc)
+{
+	struct reserved_mem *rmem;
+	struct device_node *node;
+
+	node = of_parse_phandle(qproc->dev->of_node,
+				"qcom,fih-nv-memory-region", 0);
+	if (!node)
+		return 0;
+
+	rmem = of_reserved_mem_lookup(node);
+	of_node_put(node);
+	if (!rmem)
+		return -EINVAL;
+
+	qproc->fih_nv_phys = rmem->base;
+	qproc->fih_nv_size = rmem->size;
+	qproc->fih_nv_perm = BIT(QCOM_SCM_VMID_HLOS);
+
+	return 0;
+}
+
 static int q6v5_probe(struct platform_device *pdev)
 {
 	const struct rproc_hexagon_res *desc;
@@ -2099,6 +2156,10 @@ static int q6v5_probe(struct platform_device *pdev)
 	if (ret)
 		return ret;
 
+	ret = q6v5_alloc_fih_nv_region(qproc);
+	if (ret)
+		return ret;
+
 	ret = q6v5_init_clocks(&pdev->dev, qproc->proxy_clks,
 			       desc->proxy_clk_names);
 	if (ret < 0)
-- 
