+static bool q6v5_diag_looks_printable(const char *msg, size_t len)
+{
+	size_t i;
+
+	if (!len || !msg[0])
+		return false;
+
+	for (i = 0; i < len && i < 96 && msg[i]; i++) {
+		if (msg[i] == '\n' || msg[i] == '\r' || msg[i] == '\t')
+			continue;
+		if (msg[i] < 0x20 || msg[i] > 0x7e)
+			return false;
+	}
+
+	return i > 0;
+}
+
+static void q6v5_diag_dump_smem_item(struct qcom_q6v5 *q6v5,
+				     const char *reason, int host, int item)
+{
+	size_t len = 0;
+	u8 *msg;
+	size_t dump_len;
+
+	msg = qcom_smem_get(host, item, &len);
+	if (IS_ERR(msg)) {
+		dev_info(q6v5->dev,
+			 "q6v5 diag %s: smem host=%d item=%d err=%ld\n",
+			 reason, host, item, PTR_ERR(msg));
+		return;
+	}
+
+	if (!len) {
+		dev_info(q6v5->dev,
+			 "q6v5 diag %s: smem host=%d item=%d len=0\n",
+			 reason, host, item);
+		return;
+	}
+
+	dump_len = min_t(size_t, len, 96);
+	if (q6v5_diag_looks_printable(msg, dump_len))
+		dev_info(q6v5->dev,
+			 "q6v5 diag %s: smem host=%d item=%d len=%zu text=\"%.*s\"\n",
+			 reason, host, item, len, (int)dump_len, msg);
+	else
+		dev_info(q6v5->dev,
+			 "q6v5 diag %s: smem host=%d item=%d len=%zu first16=%*ph\n",
+			 reason, host, item, len, (int)min_t(size_t, len, 16), msg);
+}
+
+static void q6v5_diag_dump_crash_smem(struct qcom_q6v5 *q6v5,
+				      const char *reason)
+{
+	/* Host 1 is the modem private SMEM partition on Qualcomm platforms. */
+	q6v5_diag_dump_smem_item(q6v5, reason, QCOM_SMEM_HOST_ANY, q6v5->crash_reason);
+	q6v5_diag_dump_smem_item(q6v5, reason, 1, q6v5->crash_reason);
+	q6v5_diag_dump_smem_item(q6v5, reason, QCOM_SMEM_HOST_ANY, 6);
+	q6v5_diag_dump_smem_item(q6v5, reason, 1, 6);
+}
