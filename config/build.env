# Official global Ubuntu Ports mirror. Override at build time with
# RAZER_UBUNTU_MIRROR=https://your-nearby-mirror.example/ubuntu-ports
: "${RAZER_UBUNTU_MIRROR:=https://ports.ubuntu.com/ubuntu-ports}"

# Hardware image profile. Supported values: base
: "${RAZER_IMAGE_PROFILE:=base}"

# Optional userspace payload layered on top of the hardware platform image.
# The default release installs no app stack. CI maps tag suffixes such as
# v1.0.0-ha and v1.0.0-3dprinter to these values.
# Supported values: none, ha, 3dprinter
: "${RAZER_USERSPACE_PROFILE:=none}"
