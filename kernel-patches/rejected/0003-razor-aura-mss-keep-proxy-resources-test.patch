diff --git a/drivers/remoteproc/qcom_q6v5_mss.c b/drivers/remoteproc/qcom_q6v5_mss.c
index d73f6f2c9c3a..6f77fd24eeca 100644
--- a/drivers/remoteproc/qcom_q6v5_mss.c
+++ b/drivers/remoteproc/qcom_q6v5_mss.c
@@ -1783,6 +1783,16 @@ static void qcom_msa_handover(struct qcom_q6v5 *q6v5)
 {
 	struct q6v5 *qproc = container_of(q6v5, struct q6v5, q6v5);
 
+	/*
+	 * Razer's downstream MSS node has an explicit proxy-unvote GPIO and
+	 * downstream-specific AOP signalling. Keep proxy resources voted during
+	 * the live SDM845/aura test to check whether mainline releases them too
+	 * early, before the modem reaches wlan_pd / WLFW.
+	 */
+	if (qproc->version == MSS_SDM845) {
+		dev_info(qproc->dev, "sdm845 mss diag: keeping proxy resources after handover\n");
+		return;
+	}
+
 	q6v5_clk_disable(qproc->dev, qproc->proxy_clks,
 			 qproc->proxy_clk_count);
 	q6v5_regulator_disable(qproc, qproc->proxy_regs,
